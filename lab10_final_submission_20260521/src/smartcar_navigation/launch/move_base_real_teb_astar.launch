<launch>
    <arg name="cmd_vel_topic" default="/cmd_vel"/>
    <arg name="odom_topic" default="odom"/>
    <arg name="scan_topic" default="/limo/scan"/>
    <arg name="sensor_frame" default="laser_link"/>
    <arg name="base_frame" default="base_footprint"/>
    <arg name="map_frame" default="map"/>

    <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
        <param name="base_local_planner" value="teb_local_planner/TebLocalPlannerROS"/>
        <param name="base_global_planner" value="global_planner/GlobalPlanner"/>

        <rosparam file="$(find smartcar_navigation)/param/costmap_common_params.yaml" command="load" ns="global_costmap"/>
        <rosparam file="$(find smartcar_navigation)/param/costmap_common_params.yaml" command="load" ns="local_costmap"/>
        <rosparam file="$(find smartcar_navigation)/param/local_costmap_params.yaml" command="load"/>
        <rosparam file="$(find smartcar_navigation)/param/global_costmap_params.yaml" command="load"/>
        <rosparam file="$(find smartcar_navigation)/param/move_base_params.yaml" command="load"/>
        <rosparam file="$(find smartcar_navigation)/param/teb_local_planner_params.yaml" command="load"/>
        <rosparam file="$(find smartcar_navigation)/param/global_planner_params.yaml" command="load"/>

        <param name="global_costmap/robot_base_frame" value="$(arg base_frame)"/>
        <param name="local_costmap/robot_base_frame" value="$(arg base_frame)"/>
        <param name="global_costmap/scan/topic" value="$(arg scan_topic)"/>
        <param name="local_costmap/scan/topic" value="$(arg scan_topic)"/>
        <param name="global_costmap/scan/sensor_frame" value="$(arg sensor_frame)"/>
        <param name="local_costmap/scan/sensor_frame" value="$(arg sensor_frame)"/>
        <param name="TebLocalPlannerROS/odom_topic" value="$(arg odom_topic)"/>
        <param name="TebLocalPlannerROS/map_frame" value="$(arg map_frame)"/>

        <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/>
        <remap from="odom" to="$(arg odom_topic)"/>
    </node>
</launch>
