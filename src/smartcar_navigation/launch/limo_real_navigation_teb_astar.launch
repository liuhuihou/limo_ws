<launch>
    <arg name="map_file" default="$(env HOME)/myfile/robote_project/limo_ws/map/map.yaml"/>
    <arg name="use_rviz" default="true"/>
    <arg name="scan_topic" default="/limo/scan"/>
    <arg name="sensor_frame" default="laser_link"/>
    <arg name="cmd_vel_topic" default="/cmd_vel"/>
    <arg name="odom_topic" default="odom"/>
    <arg name="odom_frame" default="odom"/>
    <arg name="base_frame" default="base_footprint"/>
    <arg name="global_frame" default="map"/>

    <node name="map_server" pkg="map_server" type="map_server" args="$(arg map_file)"/>

    <include file="$(find smartcar_navigation)/launch/amcl_real.launch">
        <arg name="scan_topic" value="$(arg scan_topic)"/>
        <arg name="odom_frame" value="$(arg odom_frame)"/>
        <arg name="base_frame" value="$(arg base_frame)"/>
        <arg name="global_frame" value="$(arg global_frame)"/>
    </include>

    <include file="$(find smartcar_navigation)/launch/move_base_real_teb_astar.launch">
        <arg name="cmd_vel_topic" value="$(arg cmd_vel_topic)"/>
        <arg name="odom_topic" value="$(arg odom_topic)"/>
        <arg name="scan_topic" value="$(arg scan_topic)"/>
        <arg name="sensor_frame" value="$(arg sensor_frame)"/>
        <arg name="base_frame" value="$(arg base_frame)"/>
        <arg name="map_frame" value="$(arg global_frame)"/>
    </include>

    <node if="$(arg use_rviz)" pkg="rviz" type="rviz" name="rviz" args="-d $(find smartcar_navigation)/rviz/nav_teb.rviz"/>
</launch>
